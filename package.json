{
  "name": "vscode-agent-lsp",
  "displayName": "agent-lsp",
  "description": "Language intelligence for AI agents: 65 tools, 24 skills, 30 languages.",
  "version": "0.1.0",
  "publisher": "blackwell-systems",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "keywords": [
    "mcp",
    "lsp",
    "ai",
    "agent",
    "code-intelligence",
    "refactoring"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [],
    "configuration": {
      "title": "agent-lsp",
      "properties": {
        "agent-lsp.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to agent-lsp binary (leave empty to use PATH)"
        },
        "agent-lsp.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional arguments for agent-lsp"
        },
        "agent-lsp.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start server automatically on workspace open"
        },
        "agent-lsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace level for server communication"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-lsp",
          "title": "Agent LSP",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "agent-lsp": [
        {
          "id": "agentLsp.inspector",
          "name": "Inspection"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.ts",
    "watch": "node esbuild.config.ts --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "package": "vsce package",
    "compile": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
